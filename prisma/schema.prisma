generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String              @id @default(cuid())
  clerkId              String              @unique
  email                String              @unique
  name                 String?
  imageUrl             String?
  role                 UserRole            @default(USER)
  plan                 SubscriptionPlan    @default(FREE)
  stripeCustomerId     String?             @unique
  stripeSubscriptionId String?             @unique
  subscriptionStatus   SubscriptionStatus?
  calculationsUsed     Int                 @default(0)
  calculationsLimit    Int                 @default(3)
  periodStart          DateTime?
  periodEnd            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  calculations         Calculation[]
  contributedRates     ContributedRate[]
  rateCards            RateCard[]

  @@index([clerkId])
  @@index([email])
  @@index([stripeCustomerId])
}

model Calculation {
  id                 String   @id @default(cuid())
  userId             String
  platform           String
  username           String?
  followerCount      Int
  engagementRate     Float
  contentType        String
  niche              String
  audienceLocation   String
  deliverables       String
  usageRights        String
  exclusivity        String
  minRate            Int
  maxRate            Int
  recommendedRate    Int
  baseRate           Int
  nicheMultiplier    Float
  usageRightsPremium Int
  exclusivityPremium Int
  confidenceScore    Int
  dataPoints         Int
  breakdown          Json?
  marketContext      Json?
  negotiationGuidance Json?
  warning            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([niche])
  @@index([createdAt])
}

model Rate {
  id              String   @id @default(cuid())
  platform        String
  followerRange   String
  engagementRange String
  niche           String
  contentType     String
  usageRights     String
  exclusivity     String
  minRate         Int
  maxRate         Int
  averageRate     Int
  dataPoints      Int
  lastUpdated     DateTime
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([platform, followerRange, engagementRange])
  @@index([niche])
  @@index([isVerified])
}

model ContributedRate {
  id             String             @id @default(cuid())
  userId         String
  platform       String
  followerCount  Int
  engagementRate Float
  niche          String
  contentType    String
  actualPayment  Int
  usageRights    String
  exclusivity    String
  status         ContributionStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model RateCard {
  id             String   @id @default(cuid())
  userId         String
  creatorName    String
  creatorHandle  String
  platform       String
  followerCount  Int
  engagementRate Float
  niche          String
  photoUrl       String?
  rates          Json
  terms          String?
  contactEmail   String?
  contactPhone   String?
  pdfUrl         String?
  templateId     String   @default("modern")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Analytics {
  id        String   @id @default(cuid())
  eventType String
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum ContributionStatus {
  PENDING
  APPROVED
  REJECTED
}
